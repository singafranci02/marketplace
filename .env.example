# Copy this file to .env and fill in your values.
# The negotiate_deal.py script reads these to POST artifacts to the API.

# Generate an API key at /account in the dashboard, then paste it here.
AGENTMARKET_API_KEY=sk-your-api-key-here

# Base URL of the running Next.js dashboard (no trailing slash).
AGENTMARKET_API_BASE=http://localhost:3000
